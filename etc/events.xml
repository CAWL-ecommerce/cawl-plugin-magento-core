<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <!-- save surcharging data when submit invoice (can be from frontend - authorize and capture)) -->
    <event name="sales_order_invoice_save_after">
        <observer name="Cawl_PaymentCore::invoice_save" instance="Cawl\PaymentCore\Observer\Sales\Model\Order\Invoice\IsInvoicedSurcharging" />
    </event>
    <event name="adminhtml_cache_flush_system">
        <observer name="Cawl_PaymentCore::flush_system_pagecache" instance="Cawl\PaymentCore\Observer\Cache\FlushPaymentProducts" />
    </event>
    <event name="adminhtml_cache_refresh_type">
        <observer name="Cawl_PaymentCore::refresh_cache" instance="Cawl\PaymentCore\Observer\Cache\FlushPaymentProducts"/>
    </event>
    <event name="adminhtml_cache_flush_all">
        <observer name="Cawl_PaymentCore::flush_all_cache" instance="Cawl\PaymentCore\Observer\Cache\FlushPaymentProducts"/>
    </event>
</config>
